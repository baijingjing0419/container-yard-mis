# ==========================================
# 本地开发环境配置
# 复制此文件为 .env 并修改即可
# ==========================================

# MySQL数据库连接配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ContainerTerminalDB

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:5173

# ==========================================
# Docker Compose 环境变量（可选）
# 在项目根目录 .env 中设置，或直接 export
# ==========================================
# MYSQL_ROOT_PASSWORD=root          # MySQL root 密码（默认 root）
# MYSQL_DATABASE=ContainerTerminalDB # 数据库名（默认 ContainerTerminalDB）
# DB_USER=root                      # 后端数据库用户（默认 root）
# DB_PASSWORD=root                  # 后端数据库密码（默认 root）

